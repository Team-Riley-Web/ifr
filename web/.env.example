# Local path to the folder containing the course directories.
# Defaults to the parent of the web/ folder if not set.
# CONTENT_BASE_PATH=/home/user/courses

# Add these values to Netlify and export them locally before running
# `npm run upload:content`. Do not commit real credentials.
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
