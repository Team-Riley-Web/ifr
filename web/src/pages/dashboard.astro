---
import Layout from '../layouts/Layout.astro';
import { courses } from '../lib/courses';
import { getProgress } from '../lib/data';

const user = Astro.locals.user!;

const progress = await getProgress(user.id);
const progressMap = Object.fromEntries(
  Object.entries(progress).map(([courseId, lessons]) => [
    courseId,
    Object.values(lessons).filter(Boolean).length,
  ]),
);

const courseIcons: Record<string, string> = {
  'core-skills': '🎵',
  'seven-worlds': '🌍',
  'pure-harmony-essentials': '🎶',
  'chord-melody': '🎸',
  'chord-melody-2': '🎸',
  'violin-looping': '🎻',
};
---
<Layout title="Dashboard">
  <div class="min-h-screen flex flex-col">
    <!-- Header -->
    <header class="bg-sidebar shadow-sm sticky top-0 z-10">
      <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <h1 class="text-xl font-bold text-white tracking-tight">IFR Courses</h1>
        <div class="flex items-center gap-4">
          <span class="text-slate-400 text-sm hidden sm:block">Hello, <span class="text-white font-medium">{user.username}</span></span>
          {user.isAdmin && (
            <a href="/admin/users" class="text-sm text-slate-400 hover:text-white transition px-3 py-1.5 rounded-lg hover:bg-white/10">
              Users
            </a>
          )}
          <button
            id="logout-btn"
            class="text-sm text-slate-400 hover:text-white transition px-3 py-1.5 rounded-lg hover:bg-white/10"
          >
            Sign out
          </button>
        </div>
      </div>
    </header>

    <!-- Main -->
    <main class="flex-1 max-w-6xl mx-auto w-full px-6 py-10">
      <div class="mb-8">
        <h2 class="text-2xl font-bold text-slate-800">Your Courses</h2>
        <p class="text-slate-500 mt-1 text-sm">Pick up where you left off or start a new course.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {courses.map((course, i) => {
          const total = course.lessons.length;
          const done = progressMap[course.id] ?? 0;
          const pct = total > 0 ? Math.round((done / total) * 100) : 0;
          const started = done > 0;
          const finished = done === total;

          return (
            <a
              href={`/course/${course.id}`}
              class="group bg-white rounded-2xl shadow-sm border border-slate-100 p-6 hover:shadow-md hover:border-brand-200 transition-all duration-200 flex flex-col"
            >
              <div class="flex items-start justify-between mb-4">
                <div class="w-12 h-12 rounded-xl bg-brand-50 flex items-center justify-center text-2xl flex-shrink-0">
                  {courseIcons[course.id] ?? '📚'}
                </div>
                <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${
                  finished ? 'bg-green-100 text-green-700' :
                  started  ? 'bg-brand-100 text-brand-700' :
                             'bg-slate-100 text-slate-500'
                }`}>
                  {finished ? 'Complete' : started ? 'In Progress' : 'Not Started'}
                </span>
              </div>

              <div class="flex-1">
                <p class="text-xs text-slate-400 font-medium mb-1">Course {String(i + 1).padStart(2, '0')}</p>
                <h3 class="text-lg font-semibold text-slate-800 group-hover:text-brand-600 transition-colors leading-snug">
                  {course.title}
                </h3>
                <p class="text-sm text-slate-500 mt-1">{total} lesson{total !== 1 ? 's' : ''}</p>
              </div>

              <div class="mt-5">
                <div class="flex justify-between text-xs text-slate-500 mb-1.5">
                  <span>{done} of {total} complete</span>
                  <span>{pct}%</span>
                </div>
                <div class="w-full bg-slate-100 rounded-full h-1.5">
                  <div
                    class={`h-1.5 rounded-full transition-all ${finished ? 'bg-green-500' : 'bg-brand-500'}`}
                    style={`width: ${pct}%`}
                  ></div>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </main>
  </div>
</Layout>

<script>
  document.getElementById('logout-btn')?.addEventListener('click', async () => {
    await fetch('/api/auth/logout', { method: 'POST' });
    window.location.href = '/';
  });
</script>
