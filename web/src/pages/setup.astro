---
import Layout from '../layouts/Layout.astro';
import { hasUsers } from '../lib/auth';

// Only accessible when no users exist
if (await hasUsers()) {
  return Astro.redirect('/');
}
---
<Layout title="Create Account">
  <div class="min-h-screen flex items-center justify-center bg-[radial-gradient(circle_at_top_left,rgba(214,168,79,0.22),transparent_34%),radial-gradient(circle_at_bottom_right,rgba(20,184,166,0.14),transparent_30%),linear-gradient(135deg,#050816_0%,#0b1220_48%,#111827_100%)] px-4">
    <div class="w-full max-w-sm">
      <div class="text-center mb-8">
        <p class="mb-3 text-xs font-semibold uppercase tracking-[0.28em] text-brand-500">First Access</p>
        <h1 class="text-3xl font-bold text-white tracking-tight">IFR Courses</h1>
        <p class="mt-2 text-slate-300 text-sm">Create your admin account to get started</p>
      </div>

      <div class="rounded-2xl border border-white/10 bg-white/[0.07] p-8 shadow-2xl shadow-black/40 backdrop-blur-xl">
        <form id="setup-form" class="space-y-5">
          <div>
            <label for="username" class="block text-sm font-medium text-slate-200 mb-1.5">Username</label>
            <input
              id="username"
              name="username"
              type="text"
              required
              class="w-full px-4 py-2.5 rounded-lg border border-white/10 bg-slate-950/70 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition"
              placeholder="Choose a username"
            />
          </div>
          <div>
            <label for="password" class="block text-sm font-medium text-slate-200 mb-1.5">Password</label>
            <input
              id="password"
              name="password"
              type="password"
              required
              minlength="8"
              class="w-full px-4 py-2.5 rounded-lg border border-white/10 bg-slate-950/70 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition"
              placeholder="Min. 8 characters"
            />
          </div>
          <div id="error-msg" class="hidden text-sm text-red-200 bg-red-950/60 border border-red-400/30 rounded-lg px-4 py-2.5"></div>
          <button
            type="submit"
            class="w-full py-2.5 px-4 bg-gradient-to-r from-brand-500 via-amber-400 to-brand-600 hover:from-brand-600 hover:to-amber-500 text-slate-950 font-semibold rounded-lg transition focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2 focus:ring-offset-slate-950 disabled:opacity-60"
          >
            Create Account
          </button>
        </form>
      </div>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('setup-form') as HTMLFormElement;
  const errorMsg = document.getElementById('error-msg') as HTMLDivElement;
  const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMsg.classList.add('hidden');
    btn.disabled = true;

    const data = Object.fromEntries(new FormData(form));
    const res = await fetch('/api/auth/setup', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    });

    if (res.ok) {
      window.location.href = '/dashboard';
    } else {
      const { error } = await res.json().catch(() => ({ error: 'Setup failed' }));
      errorMsg.textContent = error;
      errorMsg.classList.remove('hidden');
      btn.disabled = false;
    }
  });
</script>
